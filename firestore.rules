rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Donor_Profiles/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /Milk_Inquiries/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /Milk_Batches/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /Milk_State_Logs/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
